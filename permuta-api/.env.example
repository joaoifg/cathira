ENV=dev
PORT=8080

# Quando true, expõe POST /dev/login que cria um user fake e devolve JWT válido.
# Manter sempre false em produção.
DEV_MODE=false

# Dashboard → Project Settings → Database → Connection string (URI)
# Ex.: postgres://postgres:SENHA@db.<project>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

SUPABASE_URL=https://<project>.supabase.co

# Dashboard → Project Settings → API → API Keys
# - Publishable (sb_publishable_*) → vai pro cliente Flutter
# - Secret      (sb_secret_*)      → só no backend (bypass RLS quando necessário)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Dashboard → Project Settings → API → JWT Keys → Legacy JWT secret
# É com isso que validamos o Bearer <token> que o Flutter manda.
SUPABASE_JWT_SECRET=
